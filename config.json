{
  "targets": ["localhost"],
  "output_dir": "./reports",
  "concurrent_tests": 3,
  "safe_mode": true,
  "tests": {
    "port_scan": {
      "enabled": true,
      "ports": [22, 80, 443, 3306, 5432, 6379, 8080, 8443, 9200, 27017],
      "timeout": 2
    },
    "weak_creds": {
      "enabled": true,
      "check_paths": ["/etc/passwd", "/etc/shadow", "/etc/hosts"]
    },
    "ssl_tls": {
      "enabled": true,
      "port": 443
    },
    "container_escape": {
      "enabled": true
    }
  }
}
